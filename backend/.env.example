# =====================================================================
#  Ipak Yo'li — backend sozlamalari (SQLite)
#  start.sh / start.bat bu fayldan .env yaratadi (agar mavjud bo'lmasa).
# =====================================================================

# SQLite baza fayli (tashqi baza kerak emas — lokal fayl).
# Nisbiy yo'l backend/ papkasiga nisbatan. Standart: backend/ipak.db
DATABASE_URL=sqlite:///./ipak.db

# Backend porti (frontend .env dagi VITE_API_URL shu portga mos bo'lsin)
PORT=4000

# Auth / JWT (ishlab chiqarishda albatta almashtiring)
JWT_SECRET=dev-secret-almashtiring
JWT_ALG=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS — ruxsat etilgan domenlar (vergul bilan). Bo'sh -> hammaga (dev)
ALLOWED_ORIGINS=

# Boshlang'ich super-admin (init_db.py birinchi ishga tushganda parolni o'rnatadi)
ADMIN_EMAIL=admin@ipakyoli.uz
ADMIN_PASSWORD=admin12345

# AI provayder (ixtiyoriy): qaysi kalit bo'lsa, o'sha ishlatiladi
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# AI_API_KEY=            # OpenAI-mos custom provayder
# AI_BASE_URL=           # custom provayder bazaviy URL
# AI_MODEL=              # bo'sh bo'lsa provayder standarti
