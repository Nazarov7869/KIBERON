<% var sfx = (typeof sfx!=='undefined')?sfx:'x'; var theme=(typeof theme!=='undefined')?theme:'light'; var sub=(typeof sub!=='undefined')?sub:true; %>
<span class="logo logo--<%= theme %>">
  <svg class="logo-mark" viewBox="0 0 100 100" width="34" height="34" aria-hidden="true" focusable="false">
    <defs>
      <linearGradient id="lgr-<%= sfx %>" x1="0" y1="0" x2="1" y2="1"><stop offset="0" stop-color="#F7DB86"/><stop offset=".5" stop-color="#E0AF48"/><stop offset="1" stop-color="#B87E1C"/></linearGradient>
      <linearGradient id="lgl-<%= sfx %>" x1="0" y1="0" x2="1" y2="1"><stop offset="0" stop-color="#FCE7A6"/><stop offset="1" stop-color="#E9BE5C"/></linearGradient>
      <linearGradient id="lgd-<%= sfx %>" x1="0" y1="0" x2="1" y2="1"><stop offset="0" stop-color="#C88F24"/><stop offset="1" stop-color="#9A6A15"/></linearGradient>
    </defs>
    <circle cx="50" cy="50" r="46" fill="url(#lgr-<%= sfx %>)"/>
    <circle cx="50" cy="50" r="42.2" fill="#23282F"/>
    <path d="M50,50 L50,13 L42,42 Z" fill="url(#lgl-<%= sfx %>)"/><path d="M50,50 L79,50 L58,42 Z" fill="url(#lgl-<%= sfx %>)"/>
    <path d="M50,50 L50,87 L58,58 Z" fill="url(#lgl-<%= sfx %>)"/><path d="M50,50 L21,50 L42,58 Z" fill="url(#lgl-<%= sfx %>)"/>
    <path d="M50,50 L50,13 L58,42 Z" fill="url(#lgd-<%= sfx %>)"/><path d="M50,50 L79,50 L58,58 Z" fill="url(#lgd-<%= sfx %>)"/>
    <path d="M50,50 L50,87 L42,58 Z" fill="url(#lgd-<%= sfx %>)"/><path d="M50,50 L21,50 L42,42 Z" fill="url(#lgd-<%= sfx %>)"/>
    <path d="M50,13 L58,42 L79,50 L58,58 L50,87 L42,58 L21,50 L42,42 Z" fill="none" stroke="#8A6316" stroke-width="0.6" stroke-linejoin="round"/>
    <circle cx="50" cy="50" r="5.4" fill="#23282F"/><circle cx="50" cy="50" r="5.4" fill="none" stroke="url(#lgr-<%= sfx %>)" stroke-width="1.1"/>
  </svg>
  <span class="logo-word">
    <span class="logo-top"><span class="logo-silk">SILK</span><span class="logo-road">ROAD</span></span>
    <% if (sub) { %><span class="logo-sub">EXPORT INTELLIGENCE MAP</span><% } %>
  </span>
</span>
